# Tu servidor Railway
SELF_URL=https://bimetria-production.up.railway.app

# ID4FACE - biometría y extra-document
BASE_URL=https://id4face.eclipsoft.dev
EXTRA_DOCUMENT_BASE_URL=https://id4face.eclipsoft.dev
